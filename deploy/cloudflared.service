[Unit]
Description=Cloudflare Tunnel (OpenClaude quick tunnel)
After=network.target openclaude.service

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/cloudflared tunnel --url http://127.0.0.1:18789 --no-autoupdate
Restart=always
RestartSec=5
StandardOutput=append:/var/log/cloudflared.log
StandardError=append:/var/log/cloudflared.log

[Install]
WantedBy=multi-user.target
