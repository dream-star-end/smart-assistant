# ──────────────────────────────────────────────────────────────
# OpenClaude Commercial (v2) 环境变量模板
# 复制到 /etc/openclaude/commercial.env,填实值。
# 权限应为 chmod 600,owner root,systemd EnvironmentFile= 指向它。
# ──────────────────────────────────────────────────────────────

# === 开关(必填)===
COMMERCIAL_ENABLED=1

# === 存储(必填)===
DATABASE_URL=postgresql://openclaude:CHANGE_ME@127.0.0.1:5432/openclaude_commercial
REDIS_URL=redis://127.0.0.1:6379

# === 密钥(必填)===
# openssl rand -hex 64
COMMERCIAL_JWT_SECRET=CHANGE_ME_TO_64_BYTE_HEX
# openssl rand -base64 32  (base64 解码后必须正好 32 bytes,用于 AES-256-GCM 加密 Claude 账号池)
OPENCLAUDE_KMS_KEY=CHANGE_ME_BASE64_32BYTES

# === 基础 URL(邮件里验证/重置链接用)===
COMMERCIAL_BASE_URL=https://claudeai.chat

# === Turnstile(Cloudflare 人机校验)===
# 注意:schema 拒绝空字符串,要么给非空值,要么整行删除/注释。
# 生产前请设置 TURNSTILE_SECRET 并删除 TURNSTILE_TEST_BYPASS。
TURNSTILE_TEST_BYPASS=1
# TURNSTILE_SECRET=xxxxxx

# === 虎皮椒(微信支付)===
# 三件套 superRefine:要么全设,要么全删(一个有值 → 另外两个必填)。
# 占位期全部注释:
# HUPIJIAO_APP_ID=xxx
# HUPIJIAO_APP_SECRET=xxx
# HUPIJIAO_CALLBACK_URL=https://claudeai.chat/api/payment/hupi/callback
# HUPIJIAO_RETURN_URL=https://claudeai.chat/billing/success
# HUPIJIAO_ENDPOINT=https://api.xunhupay.com/payment/do.html

# === Agent sandbox(5 项必须齐,否则 /api/agent/* 返 503;chat 链路不受影响)===
AGENT_IMAGE=openclaude/agent-runtime:latest
AGENT_NETWORK=agent-net
AGENT_PROXY_URL=http://127.0.0.1:8118
AGENT_SECCOMP_PATH=/etc/openclaude/agent_seccomp.json
AGENT_RPC_SOCKET_DIR=/var/run/openclaude-agent-rpc

# === Agent 调参(可选,留空走默认)===
# AGENT_DOCKER_SOCKET=/var/run/docker.sock
# AGENT_MEMORY_MB=512
# AGENT_CPUS=1
# AGENT_PIDS_LIMIT=512
# AGENT_PLAN_PRICE_CREDITS=2900
# AGENT_PLAN_DURATION_DAYS=30
# AGENT_VOLUME_GC_DAYS=30
# AGENT_LIFECYCLE_TICK_MS=3600000

# === 运维开关 ===
# COMMERCIAL_AUTO_MIGRATE=0     # 默认自动 migrate,设为 0 则需要手动跑 npm run migrate:commercial
# COMMERCIAL_ALERTS_DISABLED=1  # 关告警调度器(T-62)
# COMMERCIAL_ALERT_TICK_MS=60000
